;; level.ghl -- DOOM level loader
;; Parses binary level data from WAD lumps into Int32Arrays

(require doomkit as kit)
(require wad as wad)
(require defs as defs)

;; Lump offsets from map marker
(define ML_THINGS 1)
(define ML_LINEDEFS 2)
(define ML_SIDEDEFS 3)
(define ML_VERTEXES 4)
(define ML_SEGS 5)
(define ML_SSECTORS 6)
(define ML_NODES 7)
(define ML_SECTORS 8)
(define ML_REJECT 9)
(define ML_BLOCKMAP 10)

;; NF_SUBSECTOR flag for BSP node children
(define NF_SUBSECTOR (kit:bit-shl 1 15))

;; Load a level from a WAD, given the map marker lump name (e.g. "E1M1")
(define level-load
  (lambda (w map-name)
    (define map-lump (w 'check-num-for-name map-name))
    (cond
      ((= map-lump -1)
       (println (string-append "ERROR: map " map-name " not found"))
       #f)
      (else (level-load-from-lump w map-lump)))))

(define level-load-from-lump
  (lambda (w map-lump)
    ;; Local aliases to keep lines short and work around identifier limits
    (define ri16 wad:read-int16)
    (define ri32 wad:read-int32)
    (define ba-get kit:byte-array-get)
    (define ba-len kit:byte-array-len)
    (define i32-set kit:int32-array-set)
    (define i32-get kit:int32-array-get)
    (define i32-new kit:new-int32-array)
    (define shl kit:bit-shl)
    (define band kit:bit-and)
    (define FB defs:FRACBITS)

    ;; --- VERTEXES: 4 bytes each (x:i16, y:i16) ---
    (define vert-data (w 'read-lump (+ map-lump ML_VERTEXES)))
    (define num-vertexes (/ (ba-len vert-data) 4))
    (define vert-x (i32-new num-vertexes))
    (define vert-y (i32-new num-vertexes))
    (define load-vertexes
      (lambda (i)
        (cond ((< i num-vertexes)
          (define off (* i 4))
          (i32-set vert-x i (shl (ri16 vert-data off) FB))
          (i32-set vert-y i (shl (ri16 vert-data (+ off 2)) FB))
          (load-vertexes (+ i 1))))))
    (load-vertexes 0)

    ;; --- SECTORS: 26 bytes each ---
    ;; floorheight(i16) ceilingheight(i16) floorpic(8) ceilpic(8)
    ;; lightlevel(i16) special(i16) tag(i16)
    (define sector-data (w 'read-lump (+ map-lump ML_SECTORS)))
    (define num-sectors (/ (ba-len sector-data) 26))
    (define sec-floorh (i32-new num-sectors))
    (define sec-ceilh (i32-new num-sectors))
    (define sec-light (i32-new num-sectors))
    (define sec-special (i32-new num-sectors))
    (define sec-tag (i32-new num-sectors))
    (define load-sectors
      (lambda (i)
        (cond ((< i num-sectors)
          (define off (* i 26))
          (i32-set sec-floorh i (shl (ri16 sector-data off) FB))
          (i32-set sec-ceilh i (shl (ri16 sector-data (+ off 2)) FB))
          (i32-set sec-light i (ri16 sector-data (+ off 20)))
          (i32-set sec-special i (ri16 sector-data (+ off 22)))
          (i32-set sec-tag i (ri16 sector-data (+ off 24)))
          (load-sectors (+ i 1))))))
    (load-sectors 0)

    ;; --- SIDEDEFS: 30 bytes each ---
    ;; textureoffset(i16) rowoffset(i16) toptexture(8) bottomtexture(8)
    ;; midtexture(8) sector(i16)
    (define side-data (w 'read-lump (+ map-lump ML_SIDEDEFS)))
    (define num-sidedefs (/ (ba-len side-data) 30))
    (define side-texoff (i32-new num-sidedefs))
    (define side-rowoff (i32-new num-sidedefs))
    (define side-sector (i32-new num-sidedefs))
    (define load-sidedefs
      (lambda (i)
        (cond ((< i num-sidedefs)
          (define off (* i 30))
          (i32-set side-texoff i (shl (ri16 side-data off) FB))
          (i32-set side-rowoff i (shl (ri16 side-data (+ off 2)) FB))
          (i32-set side-sector i (ri16 side-data (+ off 28)))
          (load-sidedefs (+ i 1))))))
    (load-sidedefs 0)

    ;; --- LINEDEFS: 14 bytes each ---
    ;; v1(i16) v2(i16) flags(i16) special(i16) tag(i16) sidenum[2](i16 each)
    (define line-data (w 'read-lump (+ map-lump ML_LINEDEFS)))
    (define num-linedefs (/ (ba-len line-data) 14))
    (define line-v1 (i32-new num-linedefs))
    (define line-v2 (i32-new num-linedefs))
    (define line-flags (i32-new num-linedefs))
    (define line-special (i32-new num-linedefs))
    (define line-tag (i32-new num-linedefs))
    (define line-side0 (i32-new num-linedefs))
    (define line-side1 (i32-new num-linedefs))
    (define load-linedefs
      (lambda (i)
        (cond ((< i num-linedefs)
          (define off (* i 14))
          (i32-set line-v1 i (ri16 line-data off))
          (i32-set line-v2 i (ri16 line-data (+ off 2)))
          (i32-set line-flags i (ri16 line-data (+ off 4)))
          (i32-set line-special i (ri16 line-data (+ off 6)))
          (i32-set line-tag i (ri16 line-data (+ off 8)))
          (i32-set line-side0 i (ri16 line-data (+ off 10)))
          (i32-set line-side1 i (ri16 line-data (+ off 12)))
          (load-linedefs (+ i 1))))))
    (load-linedefs 0)

    ;; --- SEGS: 12 bytes each ---
    ;; v1(i16) v2(i16) angle(i16) linedef(i16) side(i16) offset(i16)
    (define seg-data (w 'read-lump (+ map-lump ML_SEGS)))
    (define num-segs (/ (ba-len seg-data) 12))
    (define seg-v1 (i32-new num-segs))
    (define seg-v2 (i32-new num-segs))
    (define seg-angle (i32-new num-segs))
    (define seg-linedef (i32-new num-segs))
    (define seg-side (i32-new num-segs))
    (define seg-offset (i32-new num-segs))
    (define load-segs
      (lambda (i)
        (cond ((< i num-segs)
          (define off (* i 12))
          (i32-set seg-v1 i (ri16 seg-data off))
          (i32-set seg-v2 i (ri16 seg-data (+ off 2)))
          (i32-set seg-angle i (shl (ri16 seg-data (+ off 4)) 16))
          (i32-set seg-linedef i (ri16 seg-data (+ off 6)))
          (i32-set seg-side i (ri16 seg-data (+ off 8)))
          (i32-set seg-offset i (shl (ri16 seg-data (+ off 10)) FB))
          (load-segs (+ i 1))))))
    (load-segs 0)

    ;; --- SSECTORS: 4 bytes each ---
    ;; numsegs(i16) firstseg(i16)
    (define ssec-data (w 'read-lump (+ map-lump ML_SSECTORS)))
    (define num-ssectors (/ (ba-len ssec-data) 4))
    (define ssec-numsegs (i32-new num-ssectors))
    (define ssec-firstseg (i32-new num-ssectors))
    (define load-ssectors
      (lambda (i)
        (cond ((< i num-ssectors)
          (define off (* i 4))
          (i32-set ssec-numsegs i (ri16 ssec-data off))
          (i32-set ssec-firstseg i (ri16 ssec-data (+ off 2)))
          (load-ssectors (+ i 1))))))
    (load-ssectors 0)

    ;; --- NODES: 28 bytes each ---
    ;; x(i16) y(i16) dx(i16) dy(i16) bbox[2][4](8xi16) children[2](u16)
    (define node-data (w 'read-lump (+ map-lump ML_NODES)))
    (define num-nodes (/ (ba-len node-data) 28))
    (define node-x (i32-new num-nodes))
    (define node-y (i32-new num-nodes))
    (define node-dx (i32-new num-nodes))
    (define node-dy (i32-new num-nodes))
    (define node-bbox (i32-new (* num-nodes 8)))
    (define node-child0 (i32-new num-nodes))
    (define node-child1 (i32-new num-nodes))
    (define load-node-bbox
      (lambda (nd off base j)
        (cond ((< j 8)
          (i32-set node-bbox (+ base j) (shl (ri16 nd (+ off 8 (* j 2))) FB))
          (load-node-bbox nd off base (+ j 1))))))
    (define load-nodes
      (lambda (i)
        (cond ((< i num-nodes)
          (define off (* i 28))
          (i32-set node-x i (shl (ri16 node-data off) FB))
          (i32-set node-y i (shl (ri16 node-data (+ off 2)) FB))
          (i32-set node-dx i (shl (ri16 node-data (+ off 4)) FB))
          (i32-set node-dy i (shl (ri16 node-data (+ off 6)) FB))
          (load-node-bbox node-data off (* i 8) 0)
          (i32-set node-child0 i (band (ri16 node-data (+ off 24)) 65535))
          (i32-set node-child1 i (band (ri16 node-data (+ off 26)) 65535))
          (load-nodes (+ i 1))))))
    (load-nodes 0)

    ;; --- THINGS: 10 bytes each ---
    ;; x(i16) y(i16) angle(i16) type(i16) options(i16)
    (define thing-data (w 'read-lump (+ map-lump ML_THINGS)))
    (define num-things (/ (ba-len thing-data) 10))
    (define thing-x (i32-new num-things))
    (define thing-y (i32-new num-things))
    (define thing-angle (i32-new num-things))
    (define thing-type (i32-new num-things))
    (define thing-options (i32-new num-things))
    (define load-things
      (lambda (i)
        (cond ((< i num-things)
          (define off (* i 10))
          (i32-set thing-x i (shl (ri16 thing-data off) FB))
          (i32-set thing-y i (shl (ri16 thing-data (+ off 2)) FB))
          (i32-set thing-angle i (ri16 thing-data (+ off 4)))
          (i32-set thing-type i (ri16 thing-data (+ off 6)))
          (i32-set thing-options i (ri16 thing-data (+ off 8)))
          (load-things (+ i 1))))))
    (load-things 0)

    ;; --- BLOCKMAP ---
    (define bmap-data (w 'read-lump (+ map-lump ML_BLOCKMAP)))
    (define bmap-orgx (shl (ri16 bmap-data 0) FB))
    (define bmap-orgy (shl (ri16 bmap-data 2) FB))
    (define bmap-width (ri16 bmap-data 4))
    (define bmap-height (ri16 bmap-data 6))

    ;; --- REJECT ---
    (define reject-data (w 'read-lump (+ map-lump ML_REJECT)))

    ;; Find player 1 start (thing type 1)
    (define find-player-start
      (lambda (i)
        (cond
          ((>= i num-things) (list 0 0 0))
          ((= (i32-get thing-type i) 1)
           (list (i32-get thing-x i) (i32-get thing-y i) (i32-get thing-angle i)))
          (else (find-player-start (+ i 1))))))
    (define player-start (find-player-start 0))

    ;; Return level object as closure
    (lambda (msg . args)
      (cond
        ((eq? msg 'num-vertexes) num-vertexes)
        ((eq? msg 'num-sectors) num-sectors)
        ((eq? msg 'num-sidedefs) num-sidedefs)
        ((eq? msg 'num-linedefs) num-linedefs)
        ((eq? msg 'num-segs) num-segs)
        ((eq? msg 'num-ssectors) num-ssectors)
        ((eq? msg 'num-nodes) num-nodes)
        ((eq? msg 'num-things) num-things)
        ((eq? msg 'vertex-x) (i32-get vert-x (car args)))
        ((eq? msg 'vertex-y) (i32-get vert-y (car args)))
        ((eq? msg 'sector-floorh) (i32-get sec-floorh (car args)))
        ((eq? msg 'sector-ceilh) (i32-get sec-ceilh (car args)))
        ((eq? msg 'sector-light) (i32-get sec-light (car args)))
        ((eq? msg 'line-v1) (i32-get line-v1 (car args)))
        ((eq? msg 'line-v2) (i32-get line-v2 (car args)))
        ((eq? msg 'line-flags) (i32-get line-flags (car args)))
        ((eq? msg 'line-side0) (i32-get line-side0 (car args)))
        ((eq? msg 'line-side1) (i32-get line-side1 (car args)))
        ((eq? msg 'side-sector) (i32-get side-sector (car args)))
        ((eq? msg 'side-texoff) (i32-get side-texoff (car args)))
        ((eq? msg 'seg-v1) (i32-get seg-v1 (car args)))
        ((eq? msg 'seg-v2) (i32-get seg-v2 (car args)))
        ((eq? msg 'seg-angle) (i32-get seg-angle (car args)))
        ((eq? msg 'seg-linedef) (i32-get seg-linedef (car args)))
        ((eq? msg 'seg-side) (i32-get seg-side (car args)))
        ((eq? msg 'seg-offset) (i32-get seg-offset (car args)))
        ((eq? msg 'ssec-numsegs) (i32-get ssec-numsegs (car args)))
        ((eq? msg 'ssec-firstseg) (i32-get ssec-firstseg (car args)))
        ((eq? msg 'node-x) (i32-get node-x (car args)))
        ((eq? msg 'node-y) (i32-get node-y (car args)))
        ((eq? msg 'node-dx) (i32-get node-dx (car args)))
        ((eq? msg 'node-dy) (i32-get node-dy (car args)))
        ((eq? msg 'node-child0) (i32-get node-child0 (car args)))
        ((eq? msg 'node-child1) (i32-get node-child1 (car args)))
        ((eq? msg 'node-bbox)
         (i32-get node-bbox (+ (* (car args) 8) (car (cdr args)))))
        ((eq? msg 'thing-x) (i32-get thing-x (car args)))
        ((eq? msg 'thing-y) (i32-get thing-y (car args)))
        ((eq? msg 'thing-angle) (i32-get thing-angle (car args)))
        ((eq? msg 'thing-type) (i32-get thing-type (car args)))
        ((eq? msg 'bmap-orgx) bmap-orgx)
        ((eq? msg 'bmap-orgy) bmap-orgy)
        ((eq? msg 'bmap-width) bmap-width)
        ((eq? msg 'bmap-height) bmap-height)
        ((eq? msg 'player-start-x) (car player-start))
        ((eq? msg 'player-start-y) (car (cdr player-start)))
        ((eq? msg 'player-start-angle) (car (cdr (cdr player-start))))
        (else (println "level: unknown message"))))))
